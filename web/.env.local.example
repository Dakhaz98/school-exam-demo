# Copy to .env.local and fill in values.

# Supabase (required for auth + data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Express exam-realtime service (Render URL or local). Used server-side for deep links from /exam/[id].
# Example: https://school-exam-demo1.onrender.com
EXAM_REALTIME_URL=

# LiveKit (optional — proctoring token API returns 503 until set)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Client SDK often uses:
# NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR_HOST
